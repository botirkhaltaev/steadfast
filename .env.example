# AI Gateway / OpenAI (required for the coach + vision)
# On Vercel, AI Gateway OIDC can replace a raw key.
AI_GATEWAY_API_KEY=
# Optional direct OpenAI key if not using Gateway
OPENAI_API_KEY=

# Model overrides (AI Gateway ids)
EVE_MODEL=openai/gpt-5.4-mini
EVE_VISION_MODEL=openai/gpt-5.4-mini

# Wassist BYOA (WhatsApp pipe)
WASSIST_API_KEY=
WASSIST_API_BASE=https://backend.wassist.app/api/v1
# Optional: HMAC secret for x-wassist-signature (platform webhooks), or
# exact-match X-Wassist-Secret / X-Steadfast-Webhook-Secret. BYOA posts
# without these headers today — requests without auth headers are allowed.
WASSIST_WEBHOOK_SECRET=
# After deploy, set BYOA webhookUrl to:
#   https://<your-deployment>/webhook
# Production: https://steadfast-olive.vercel.app/webhook

# Runware (meal upgrade visuals)
RUNWARE_API_KEY=
RUNWARE_MODEL=runware:400@1
# Hackathon credit code (redeem in Runware dashboard): ReimagineRUNWARE

# Clinician escalation sink (Slack incoming webhook, PagerDuty, etc.)
CLINICIAN_WEBHOOK_URL=
