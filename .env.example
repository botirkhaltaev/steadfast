# AI Gateway / OpenAI (required for the coach + vision)
# On Vercel, AI Gateway OIDC can replace a raw key.
AI_GATEWAY_API_KEY=
# Optional direct OpenAI key if not using Gateway
OPENAI_API_KEY=

# Model overrides (AI Gateway ids)
EVE_MODEL=openai/gpt-5.4-mini
EVE_VISION_MODEL=openai/gpt-5.4-mini
# Inbound WhatsApp voice-note transcription (AI Gateway OpenAI STT)
# gpt-4o-mini-transcribe: best default (accuracy + cost)
# gpt-4o-transcribe: higher quality on noisy/accented audio
# openai/whisper-1: legacy
EVE_TRANSCRIBE_MODEL=openai/gpt-4o-mini-transcribe

# Wassist (platform webhook + Conversations API)
WASSIST_API_KEY=
WASSIST_API_BASE=https://backend.wassist.app/api/v1
# Signing secret from wassist.app/developers/webhooks (x-wassist-signature)
WASSIST_WEBHOOK_SECRET=
# Webhook URL to register (withEve proxies /eve/v1/**):
#   https://steadfast-olive.vercel.app/eve/v1/wassist/webhook

# Runware (meal upgrade visuals)
RUNWARE_API_KEY=
RUNWARE_MODEL=runware:400@1
# Hackathon credit code (redeem in Runware dashboard): ReimagineRUNWARE

# Neon Postgres (shared escalations, session epoch, Gemini Live link registry).
# Provision via: vercel integration add neon && vercel env pull .env.local
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Optional Slack/PagerDuty webhook when Scout escalates to a human clinician.
CLINICIAN_WEBHOOK_URL=

# Optional: only if the clinician UI must call a remote Eve origin.
# With withEve (default), the UI uses same-origin /clinician/* rewrites.
# NEXT_PUBLIC_EVE_URL=http://localhost:3000

# Optional floor for session epoch (also bumped by open POST /reset-all into Neon app_meta)
# DEMO_SESSION_EPOCH=0

# Gemini Live — Tasso+ browser device helper (voice + vision)
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Native-audio Live model (Preview; override if Google renames it)
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Public origin used in WhatsApp links (no trailing slash)
PUBLIC_BASE_URL=https://steadfast-olive.vercel.app
# HMAC secret for one-time device-support links (falls back to WASSIST_WEBHOOK_SECRET)
DEVICE_SUPPORT_LINK_SECRET=
