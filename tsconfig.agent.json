{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "#*": ["./agent/*"]
    }
  },
  "include": ["agent/**/*.ts", "evals/**/*.ts"]
}
