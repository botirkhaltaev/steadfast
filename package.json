{
  "name": "scout-and-sage",
  "version": "0.1.0",
  "description": "Scout & Sage — WhatsApp dual AI care companion + clinician (Wassist webhooks + Vercel Eve)",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:eve": "eve dev",
    "build": "npm run build:eve && next build",
    "build:eve": "eve build",
    "start": "next start",
    "start:eve": "eve start",
    "typecheck": "tsc --noEmit -p tsconfig.agent.json && tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/connect": "0.4.0",
    "ai": "^7.0.26",
    "drizzle-orm": "^0.45.2",
    "eve": "^0.25.1",
    "next": "^15.5.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint-config-next": "^15.5.9",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ai": "^7.0.26"
  },
  "engines": {
    "node": "24.x"
  }
}
